# ── App Security ─────────────────────────────────────────────────────────────
# Shared password gate for early access. Leave blank to disable auth (local dev).
APP_PASSWORD=

# Flask session signing key. Generate: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# ── Database (Railway sets this automatically when you add the PostgreSQL plugin) ─
DATABASE_URL=postgresql://user:password@localhost:5432/maritime_osint

# ── AIS Stream (Session 2 — real-time vessel positions) ──────────────────────
# Sign up free at https://aisstream.io to get an API key.
# Leave blank to disable the live AIS feed (NOAA historical data still works).
AISSTREAM_API_KEY=

# ── Claude AI (optional — for future AI analysis features) ───────────────────
ANTHROPIC_API_KEY=

# ── Deployment ────────────────────────────────────────────────────────────────
# PORT and FLASK_ENV are set automatically by Railway. No need to set them here.
# PORT=8080
# FLASK_ENV=production
